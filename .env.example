# ============================================
# TIENDA FITNESS PRO — Variables de Entorno
# ============================================
#
# COPIA este archivo como .env.local y rellena los valores.
#
# En desarrollo: usar .env.local
# En Vercel: configurar en Project Settings > Environment Variables
#
# NUNCA subir .env.local al repositorio.
# NUNCA exponer SUPABASE_SERVICE_ROLE_KEY en el cliente.
# ============================================

# ─── Supabase ────────────────────────────────────────────────────────────────
# Obtener estos valores en: https://supabase.com/dashboard → Tu Proyecto → Settings → API

# URL del proyecto Supabase (pública, segura para frontend)
NEXT_PUBLIC_SUPABASE_URL=

# Clave anon pública (segura para el navegador, protegida por RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Clave de servicio (SOLO servidor — NUNCA exponer en cliente)
# ⛔ WARNING: Esta clave BYPASEA RLS. Solo usar en server-side code.
SUPABASE_SERVICE_ROLE_KEY=
